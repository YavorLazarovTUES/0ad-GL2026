<?xml version="1.0" encoding="utf-8"?>
<effect>
	<technique>
		<require shaders="glsl"/>
		<require shaders="spirv"/>
		<pass shader="model_common">
			<define name="USE_TRANSPARENT" value="1"/>
			<blend src="src_alpha" dst="one_minus_src_alpha"/>
			<depth func="less" mask="false"/>
			<cull mode="NONE"/>
			<polygon mode="LINE"/>
		</pass>
	</technique>
</effect>
